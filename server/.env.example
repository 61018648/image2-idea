# Platform server environment example.
# Copy to server/.env and fill real secrets before production.

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://image-test:image-test@127.0.0.1:5432/image-test?schema=public"
PLATFORM_DB_DRIVER="postgresql"

# ---- Server ----
PLATFORM_HOST="127.0.0.1"
PLATFORM_PORT="8788"
PLATFORM_ALLOWED_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"

# ---- Session ----
PLATFORM_SESSION_SECRET="please-change-me-to-a-long-random-string"
PLATFORM_DEV_MODE="false"
PLATFORM_COOKIE_SECURE="false"

# ---- Upstream image API ----
PLATFORM_OPENAI_API_KEY=""
PLATFORM_OPENAI_BASE_URL="https://api.openai.com/v1"
PLATFORM_OPENAI_IMAGE_MODEL="gpt-image-2"

# ---- Payment callback ----
PLATFORM_PAYMENT_NOTIFY_SECRET=""

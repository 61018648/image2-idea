# 平台后端环境变量示例
# 复制为 server/.env 后按需填写。请勿提交真实密钥到版本库。

# ---- 数据库（MySQL）----
# 格式：mysql://用户名:密码@主机:端口/数据库名
# 示例（本机默认 MySQL）：
DATABASE_URL="mysql://root:password@localhost:3306/gpt_image_platform"
PLATFORM_DB_DRIVER="mysql"

# ---- 会话与鉴权 ----
# 真实登录注册所需的 session 签名密钥（请用足够长的随机串）
PLATFORM_SESSION_SECRET="please-change-me-to-a-long-random-string"

# 开发模式：true 时跳过真实鉴权，便于本地无登录调试
PLATFORM_DEV_MODE="false"

# ---- 上游图像 API ----
PLATFORM_OPENAI_API_KEY=""
PLATFORM_OPENAI_BASE_URL="https://api.openai.com/v1"
PLATFORM_OPENAI_IMAGE_MODEL="gpt-image-1"

# ---- 支付回调 ----
PLATFORM_PAYMENT_NOTIFY_SECRET=""

# ---- 监听地址 ----
PLATFORM_HOST="127.0.0.1"
PLATFORM_PORT="8788"

# 允许访问平台 API 的前端域名，多个域名用英文逗号分隔。
# 本地开发默认已允许 http://127.0.0.1:5173 和 http://localhost:5173。
PLATFORM_ALLOWED_ORIGINS="https://your-domain.example.com"

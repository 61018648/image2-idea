{
  "name": "gpt-image-playground-platform-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run src",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^6.19.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}

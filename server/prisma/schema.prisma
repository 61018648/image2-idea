generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserAccount {
  id           String    @id
  email        String?   @unique
  passwordHash String?   @map("password_hash")
  displayName  String?   @map("display_name")
  role         String    @default("user")
  status       String    @default("active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  balance Balance?
  ledger  CreditLedger[]
  orders  Order[]
  jobs    GenerationJob[]

  @@map("user_accounts")
}

model Balance {
  userId           String      @id @map("user_id")
  availableCredits Int         @default(0) @map("available_credits")
  updatedAt        DateTime    @default(now()) @updatedAt @map("updated_at")

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("balances")
}

model Plan {
  id          String   @id
  name        String
  credits     Int
  priceCents  Int      @map("price_cents")
  currency    String   @default("USD")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("plans")
}

model Order {
  id                String    @id
  userId            String    @map("user_id")
  planId            String    @map("plan_id")
  status            String    @default("pending")
  amountCents       Int       @map("amount_cents")
  currency          String    @default("USD")
  credits           Int
  provider          String
  providerOrderId   String?   @map("provider_order_id")
  providerPaymentId String?   @map("provider_payment_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  paidAt            DateTime? @map("paid_at")

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan        @relation(fields: [planId], references: [id])

  @@index([userId, createdAt])
  @@map("orders")
}

model CreditLedger {
  id           String   @id
  userId       String   @map("user_id")
  type         String
  amount       Int
  balanceAfter Int      @map("balance_after")
  source       String
  sourceId     String?  @unique @map("source_id")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_ledger")
}

model PaymentEvent {
  id              String   @id
  provider        String
  providerEventId String   @map("provider_event_id")
  orderId         String?  @map("order_id")
  processedAt     DateTime @default(now()) @map("processed_at")
  raw             Json

  @@unique([provider, providerEventId])
  @@map("payment_events")
}

model GenerationJob {
  id             String    @id
  userId         String    @map("user_id")
  status         String    @default("queued")
  prompt         String
  requestParams  Json      @map("request_params")
  inputImageData Json      @default("[]") @map("input_image_data")
  maskDataUrl    String?   @map("mask_data_url")
  costCredits    Int       @map("cost_credits")
  images         Json      @default("[]")
  rawImageUrls   Json?     @map("raw_image_urls")
  revisedPrompts Json?     @map("revised_prompts")
  actualParams   Json?     @map("actual_params")
  errorMessage   String?   @map("error_message")
  createdAt      DateTime  @default(now()) @map("created_at")
  startedAt      DateTime? @map("started_at")
  finishedAt     DateTime? @map("finished_at")

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("generation_jobs")
}
